ggplot(aes(x =carat, y = log(price), color = cut)) +
geom_point(size = 0.0001) +
theme_bw()
g3 <- diamonds_sampled |>
ggplot(aes(x = carat, y = log(price), color = cut)) +
geom_point(size = 0.001) +
geom_smooth(method = "lm", se = FALSE) +
theme_bw() +
labs(title = "Vizualing the Interaction Between Petal Width (cm) and Species",
x = "Petal Width (cm)",
y = "Petal Length")
